# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=SSMSKIPQ

# Client (CORS) — comma-separated allowed frontend origins
# Local: http://localhost:5173
# Production: add your deployed frontend URL, e.g. https://your-app.example.com
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=30d

# Cloudinary (menu image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
